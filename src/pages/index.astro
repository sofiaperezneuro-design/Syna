---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="flex min-h-screen flex-col items-center justify-center bg-amber-50 p-6">
		<div class="text-center animate-fade-in">
			
			<h1 class="text-7xl md:text-9xl font-black tracking-tighter text-slate-800 mb-2">
				SYNA
			</h1>
			
			<p class="text-lg md:text-2xl text-slate-500 font-light tracking-[0.2em] uppercase">
				Estamos trabajando
			</p>

			<div class="mt-10 h-px w-20 bg-slate-300 mx-auto"></div>
			
		</div>
	</main>
</Layout>

<style>
	/* Animación suave al cargar la página */
	.animate-fade-in {
		animation: fadeIn 1.2s ease-out forwards;
	}

	@keyframes fadeIn {
		from { 
			opacity: 0; 
			transform: translateY(10px); 
		}
		to { 
			opacity: 1; 
			transform: translateY(0); 
		}
	}

	/* Ajuste opcional para la fuente si quieres que se vea más limpia */
	body {
		font-family: system-ui, -apple-system, sans-serif;
	}
</style>