---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Syna - Salud Mental y Neuropsicología">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;500;700&family=Quicksand:wght@400;600&display=swap" rel="stylesheet">

    <nav id="navbar" class="fixed top-0 w-full z-50 bg-white/95 dark:bg-[#0f0f0f]/95 backdrop-blur-md px-4 md:px-8 py-4 flex justify-between items-center shadow-sm transition-all duration-500">
        <div class="flex items-center">
            <a href="#inicio">
                <img src="/Logos/1.png" alt="Syna Logo" class="h-8 md:h-10 w-auto hover:opacity-80 transition dark:brightness-110">
            </a>
        </div>
        
        <div class="flex items-center gap-4 md:gap-8">
            <div class="hidden md:flex gap-6 font-body text-[#7D9BB7] dark:text-[#9DBEDF] font-bold text-[12px] tracking-[0.15em]">
                <a href="#inicio" class="hover:text-[#F2BA05] transition uppercase">Inicio</a>
                <a href="#quienes-somos" class="hover:text-[#F2BA05] transition uppercase">Nosotros</a>
                <a href="#servicios" class="hover:text-[#F2BA05] transition uppercase">Servicios</a>
            </div>
            
            <button id="theme-toggle" class="p-2 rounded-full bg-gray-100 dark:bg-gray-800 text-[#7D9BB7] dark:text-[#F2BA05] transition-all hover:scale-110">
                <span id="theme-toggle-light-icon" class="hidden">☀️</span>
                <span id="theme-toggle-dark-icon" class="hidden">🌙</span>
            </button>
        </div>
    </nav>

    <main class="text-[#7D9BB7] bg-[#F5E0B3] dark:bg-[#121212] transition-colors duration-500 overflow-x-hidden pt-16">
        
        <section id="inicio" class="hero-parallax relative h-[90vh] flex items-center justify-center overflow-hidden">
            <div class="absolute inset-0 bg-black/50 z-10"></div> 
            <div class="relative z-20 text-center px-6 w-full max-w-4xl mx-auto reveal">
                <img src="/Logos/2.png" alt="Syna" class="w-64 md:w-[450px] mx-auto mb-8 drop-shadow-2xl">
                
                <div class="max-w-[280px] sm:max-w-none mx-auto mb-12">
                    <h1 class="text-[14px] sm:text-lg md:text-2xl font-light uppercase tracking-[0.2em] md:tracking-[0.4em] text-white font-title leading-relaxed">
                        Salud mental y <br class="sm:hidden" /> neuropsicología
                    </h1>
                </div>

                <div class="flex flex-col sm:flex-row gap-5 justify-center items-center font-body">
                    <a href="https://wa.me/5218132438309?text=Hola!%20Comienzo%20ahora" class="btn-hero-fix gold">
                        Comienza ahora
                    </a>
                    <a href="https://www.instagram.com/psicsofiaperez/" target="_blank" class="btn-hero-fix white">
                        Instagram
                    </a>
                </div>
            </div>
        </section>

        <section id="quienes-somos" class="py-32 px-6 max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center border-b border-white/20 dark:border-gray-800 reveal">
            <div class="rounded-3xl overflow-hidden shadow-2xl transform rotate-2 hover:rotate-0 transition duration-500">
                <img src="https://images.unsplash.com/photo-1551836022-d5d88e9218df?q=80&w=1000&auto=format&fit=crop" alt="Sofía Pérez" class="w-full h-full object-cover"/>
            </div>
            <div class="font-body">
                <h2 class="text-4xl font-bold mb-8 text-[#7D9BB7] dark:text-[#9DBEDF] font-title">Quiénes Somos</h2>
                <p class="text-xl leading-relaxed mb-6 text-gray-700 dark:text-gray-300 font-light">
                    En <strong>Syna</strong>, combinamos la neuropsicología con un enfoque humano bajo la dirección de la <strong>Psic. Sofía Pérez</strong>.
                </p>
            </div>
        </section>

        <section id="servicios" class="py-32 bg-[#CFE3FE] dark:bg-[#1a2533] px-6 transition-colors">
            <div class="max-w-6xl mx-auto text-center">
                <h2 class="text-4xl font-bold mb-20 text-[#7D9BB7] dark:text-white font-title reveal">Nuestros Servicios</h2>
                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
                    <div class="service-card dark:bg-[#243141] dark:border-none reveal">
                        <div class="text-5xl mb-6 text-[#F2BA05]">🧠</div>
                        <h3 class="text-xl font-bold mb-4 font-title dark:text-white">Evaluación Neuropsicológica</h3>
                        <p class="text-gray-600 dark:text-gray-300 italic font-light font-body">Análisis detallado de funciones cognitivas.</p>
                    </div>
                    <div class="service-card dark:bg-[#243141] dark:border-none reveal">
                        <div class="text-5xl mb-6 text-[#F2BA05]">🗣️</div>
                        <h3 class="text-xl font-bold mb-4 font-title dark:text-white">Psicoterapia Individual</h3>
                        <p class="text-gray-600 dark:text-gray-300 italic font-light font-body">Acompañamiento profesional emocional.</p>
                    </div>
                    <div class="service-card dark:bg-[#243141] dark:border-none reveal">
                        <div class="text-5xl mb-6 text-[#F2BA05]">✨</div>
                        <h3 class="text-xl font-bold mb-4 font-title dark:text-white">Rehabilitación Cognitiva</h3>
                        <p class="text-gray-600 dark:text-gray-300 italic font-light font-body">Programas personalizados para fortalecer tu mente.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-32 px-6 bg-white/30 dark:bg-black/20 backdrop-blur-sm">
            <div class="max-w-4xl mx-auto text-center reveal">
                <h2 class="text-3xl font-bold mb-16 font-title dark:text-white">Lo que dicen nuestros pacientes</h2>
                <div class="grid md:grid-cols-2 gap-12 text-left font-body">
                    <div class="p-8 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border-l-4 border-[#F2BA05]">
                        <p class="text-gray-600 dark:text-gray-300 italic mb-4">"La atención de Sofía es excepcional. Me ayudó a entender mis procesos cognitivos."</p>
                        <p class="font-bold text-[#7D9BB7]">— M.R.</p>
                    </div>
                    <div class="p-8 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border-l-4 border-[#F2BA05]">
                        <p class="text-gray-600 dark:text-gray-300 italic mb-4">"Excelente profesional. El consultorio tiene una vibra de mucha paz."</p>
                        <p class="font-bold text-[#7D9BB7]">— J.L.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-32 px-6 max-w-4xl mx-auto reveal font-body">
            <h2 class="text-3xl font-bold mb-12 text-center font-title dark:text-white">Preguntas Frecuentes</h2>
            <div class="space-y-4">
                <details class="group bg-white/50 dark:bg-gray-800/50 rounded-2xl p-6 transition-all">
                    <summary class="list-none font-bold cursor-pointer flex justify-between items-center dark:text-white">
                        ¿Qué incluye la primera sesión?
                        <span class="group-open:rotate-180 transition-transform">▼</span>
                    </summary>
                    <p class="mt-4 text-gray-600 dark:text-gray-300">Entrevista clínica inicial para establecer un plan de trabajo.</p>
                </details>
            </div>
        </section>

        <section id="contacto" class="py-32 px-6 bg-[#0f0f0f] text-white">
            <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
                <div class="reveal">
                    <h2 class="text-4xl font-bold mb-6 font-title text-[#7D9BB7]">Contacto</h2>
                    <p class="text-lg text-gray-400 mb-10 font-light leading-relaxed">Agenda tu sesión y comienza a priorizar tu bienestar.</p>
                    <div class="flex flex-col gap-4 sm:max-w-xs">
                        <a href="https://wa.me/5218132438309?text=Hola!" class="btn-premium-gold text-center">Agendar sesión</a>
                        <a href="https://maps.app.goo.gl/T1CaaZqYPyCsU9hF9" target="_blank" class="btn-premium-gold outline text-center">¿Cómo llegar?</a>
                    </div>
                </div>
                <div class="map-container h-[450px]">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3596.719745169905!2d-100.298174524266!3d25.64742537742391!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8662bf00559ea967%3A0xd1aba3c231c291d!2sNeuropsicolog%C3%ADa%20%26%20Salud%20Mental!5e0!3m2!1ses-419!2smx!4v1777089199123!5m2!1ses-419!2smx" width="100%" height="100%" style="border:0;" loading="lazy"></iframe>
                </div>
            </div>
        </section>

        <footer class="bg-[#7D9BB7] dark:bg-[#0a0a0a] text-white py-16 text-center font-title transition-colors">
            <img src="/Logos/2.png" alt="Syna Logo" class="h-16 w-auto mx-auto mb-8 opacity-80">
            <p class="text-[10px] opacity-60 font-body uppercase tracking-[0.3em]">© 2026 Syna Salud Mental y Neuropsicología.</p>
        </footer>
    </main>

    <a href="https://wa.me/5218132438309" class="whatsapp-btn" target="_blank">
        <svg viewBox="0 0 32 32" width="32" height="32" fill="white"><path d="M16 .396C7.163.396 0 7.56 0 16.396c0 2.89.756 5.6 2.078 7.96L.26 31.604l7.417-1.94A15.944 15.944 0 0016 32c8.837 0 16-7.163 16-16S24.837.396 16 .396z"/></svg>
    </a>
</Layout>

<style is:global>
    .font-title { font-family: 'Montserrat', sans-serif; }
    .font-body { font-family: 'Quicksand', sans-serif; }
    html { scroll-behavior: smooth; }

    /* PARALLAX CSS PURO - MÁS ESTABLE */
    .hero-parallax {
        background-image: url('https://images.unsplash.com/photo-1494438639946-1ebd1d20bf85?q=80&w=2000');
        background-attachment: fixed;
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
    }

    .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s ease; }
    .reveal.active { opacity: 1; transform: translateY(0); }

    /* BOTONES HERO CORREGIDOS */
    .btn-hero-fix {
        display: inline-flex !important;
        align-items: center;
        justify-content: center;
        padding: 1.1rem 2.2rem;
        border-radius: 9999px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
        transition: 0.4s;
        width: auto !important; /* Evita que se estiren */
        min-width: 250px; /* Tamaño consistente */
    }

    .btn-hero-fix.gold { background: #F2BA05; color: white; box-shadow: 0 10px 20px rgba(242, 186, 5, 0.3); }
    .btn-hero-fix.white { 
        background: rgba(255, 255, 255, 0.2); 
        color: white; 
        backdrop-filter: blur(12px); 
        border: 1px solid rgba(255, 255, 255, 0.4); 
    }

    /* BOTONES CONTACTO */
    .btn-premium-gold { background: #F2BA05; color: white; font-weight: 700; padding: 1.1rem 2.2rem; border-radius: 9999px; transition: 0.4s; display: inline-block; text-transform: uppercase; font-size: 0.85rem; }
    .btn-premium-gold.outline { background: transparent; border: 2px solid #F2BA05; color: #F2BA05; }

    .service-card { background: white; padding: 3rem 2rem; border-radius: 2rem; transition: 0.4s; }
    .whatsapp-btn { position: fixed; bottom: 30px; right: 30px; width: 65px; height: 65px; background: #25D366; border-radius: 50%; display: flex; justify-content: center; align-items: center; z-index: 1000; }
</style>

<script is:inline>
    // MODO OSCURO
    const themeToggleBtn = document.getElementById('theme-toggle');
    const darkIcon = document.getElementById('theme-toggle-dark-icon');
    const lightIcon = document.getElementById('theme-toggle-light-icon');

    if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
        lightIcon.classList.remove('hidden');
    } else {
        document.documentElement.classList.remove('dark');
        darkIcon.classList.remove('hidden');
    }

    themeToggleBtn.addEventListener('click', function() {
        darkIcon.classList.toggle('hidden');
        lightIcon.classList.toggle('hidden');
        if (document.documentElement.classList.contains('dark')) {
            document.documentElement.classList.remove('dark');
            localStorage.setItem('color-theme', 'light');
        } else {
            document.documentElement.classList.add('dark');
            localStorage.setItem('color-theme', 'dark');
        }
    });

    // REVEAL ANIMATION
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>